{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "~*": ["./*"],
      "src/*": ["src/*"]
    },
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "include": ["src/**/*"]
}
